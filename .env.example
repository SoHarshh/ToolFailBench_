# Copy to .env (gitignored) and fill in what you use.

# API keys for closed-API models (only the ones you evaluate)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=

# Hugging Face token for gated open-weight models (e.g. Llama)
HF_TOKEN=

# Local vLLM server, when serving open-weight models
VLLM_BASE_URL=http://localhost:8000/v1

# LLM-judge endpoints (OpenAI-compatible vLLM, e.g. the modal_apps/ deployments)
JUDGE_QWEN35_API_BASE=
JUDGE_GLM47_API_BASE=
# Judge API keys — optional, only if your endpoint requires auth (defaults to none)
JUDGE_QWEN35_API_KEY=
JUDGE_GLM47_API_KEY=
